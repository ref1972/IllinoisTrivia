{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev Server",
      "runtimeExecutable": "/opt/homebrew/bin/npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "env": {
        "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
      }
    },
    {
      "name": "cass4-dev",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd ~/Desktop/CASS4 && npm run dev -- -p 3001"],
      "port": 3001
    },
    {
      "name": "triviaworkshop-static",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "npx --yes serve /Users/russellefriedewald/Desktop/TriviaWorkshop -p 3002 -n"],
      "port": 3002
    }
  ]
}
